<%= render PageLayout.new(title: "Users", subtitle: "#{@users.count} registered users") do %>
  <div class="table-container">
    <table class="table">
      <thead>
        <tr>
          <th>Email</th>
          <th>Role</th>
          <th>Boards</th>
          <th>Problems</th>
          <th>Activity</th>
          <th>Joined</th>
          <th>Last Login</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td>
              <div class="font-medium"><%= user.email %></div>
              <% if user.provider.present? %>
                <div class="text-xs text-muted">via <%= user.provider %></div>
              <% end %>
            </td>
            <td>
              <%= form_with model: user, url: admin_user_path(user), method: :patch do |f| %>
                <%= f.select :role, User.roles.keys, {}, onchange: "this.form.submit()", class: "inline-select" %>
              <% end %>
            </td>
            <td class="text-sm"><%= @user_stats[user.id][:boards] %></td>
            <td class="text-sm"><%= @user_stats[user.id][:problems] %></td>
            <td class="text-sm"><%= @user_stats[user.id][:activity_logs] %></td>
            <td class="text-sm text-muted">
              <%= user.created_at.strftime("%b %d, %Y") %>
            </td>
            <td class="text-sm text-muted">
              <% if user.last_sign_in_at %>
                <%= user.last_sign_in_at.strftime("%b %d, %Y") %>
              <% else %>
                <span class="text-muted">Never</span>
              <% end %>
            </td>
            <td>
              <% if user != current_user %>
                <%= link_to admin_user_path(user), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn-icon", title: "Delete" do %>
                  <%= icon(:trash) %>
                <% end %>
              <% else %>
                <span class="text-muted text-sm">You</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
