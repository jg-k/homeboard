<div class="card card-bordered comment-row">
  <div class="flex-between">
    <div>
      <div class="activity-header">
        <span class="badge badge-sm badge-<%= ActivityLogComment.category_badge_color(comment.category) %>">
          <%= comment.category.titleize %>
        </span>
        <span class="text-sm text-muted">
          on <%= comment.activity_log.loggable_type.titleize %>
          • <%= smart_date(comment.activity_log.performed_at) %>
        </span>
      </div>
      <div class="activity-notes"><%= simple_format(comment.body) %></div>
    </div>
    <div class="flex gap-2">
      <%= link_to edit_activity_log_comment_path(comment.activity_log, comment),
          class: "btn-icon", title: "Edit" do %>
        <%= icon(:edit) %>
      <% end %>
      <%= button_to activity_log_comment_path(comment.activity_log, comment),
          method: :delete,
          class: "btn-icon-danger", title: "Delete",
          data: { turbo_confirm: "Delete this comment?" } do %>
        <%= icon(:trash) %>
      <% end %>
    </div>
  </div>
</div>
