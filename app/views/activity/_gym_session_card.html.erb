<div class="card card-bordered card-gym-session activity-card">
  <div class="flex-between">
    <div>
      <div class="activity-header">
        <%= render Badge.new(:orange) { "Gym Session" } %>
        <span class="activity-title">
          <%= [
            gym_session.number_of_boulders.present? ? pluralize(gym_session.number_of_boulders, "boulder") : nil,
            gym_session.number_of_routes.present? ? pluralize(gym_session.number_of_routes, "route") : nil,
            gym_session.number_of_circuits.present? ? pluralize(gym_session.number_of_circuits, "circuit") : nil,
            gym_session.duration_minutes.present? ? "#{gym_session.duration_minutes} min" : nil
          ].compact.join(", ") %>
        </span>
      </div>
      <div class="activity-meta">
        <span><%= smart_date(activity_log.performed_at) %></span>
      </div>
      <% if gym_session.notes.present? %>
        <div class="activity-notes">
          <%= simple_format(gym_session.notes) %>
        </div>
      <% end %>
    </div>
    <% unless local_assigns[:readonly] %>
      <%= render ActivityActions.new(
        primary_action: {
          path: new_gym_session_path(
              number_of_boulders: gym_session.number_of_boulders,
              number_of_routes: gym_session.number_of_routes,
              number_of_circuits: gym_session.number_of_circuits,
              duration_minutes: gym_session.duration_minutes,
              notes: gym_session.notes
            ),
          title: "Duplicate to today",
          icon: :copy
        },
        edit_path:  edit_gym_session_path(gym_session),
        delete_path:  gym_session_path(gym_session),
        delete_confirm: "Are you sure you want to delete this activity?"

      )%>
    <% end %>
  </div>
</div>
