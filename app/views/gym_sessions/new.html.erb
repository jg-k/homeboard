<% content_for :title, "Log Gym Session" %>

<div class="page-sm">
  <h1 class="page-title">Log Activity</h1>

  <div class="tabs">
    <%= link_to new_exercise_path,
        class: "tab",
        data: { turbo_action: "replace" } do %>
      <svg class="tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="2" y1="12" x2="22" y2="12"/><rect x="4" y="7" width="3" height="10" rx="1"/><rect x="17" y="7" width="3" height="10" rx="1"/><rect x="1" y="9" width="3" height="6" rx="1"/><rect x="20" y="9" width="3" height="6" rx="1"/></svg>
      <span>Exercise</span>
    <% end %>
    <%= link_to new_gym_session_path,
        class: "tab tab-active",
        data: { turbo_action: "replace" } do %>
      <svg class="tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="4" height="4" rx="1"/><rect x="14" y="6" width="5" height="3" rx="1"/><rect x="6" y="13" width="5" height="4" rx="1"/><rect x="15" y="15" width="4" height="4" rx="1"/></svg>
      <span>Indoor Climbing</span>
    <% end %>
    <%= link_to new_hike_path,
        class: "tab",
        data: { turbo_action: "replace" } do %>
      <svg class="tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3l4 8 5-5 5 15H2L8 3z"/></svg>
      <span>Hike</span>
    <% end %>
  </div>

  <div class="card">
    <%= render "form", gym_session: @gym_session %>
  </div>
</div>
