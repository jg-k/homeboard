<% content_for :title, "Metrics" %>

<div class="page">
  <div class="page-header-flex">
    <h1 class="page-title">Metrics</h1>
    <%= link_to "New Metric", new_metric_path, class: "btn btn-primary" %>
  </div>

  <% if @metrics.any? %>
    <div class="stack">
      <% @metrics.each do |metric| %>
        <div class="card">
          <div class="flex-between">
            <div>
              <h2 class="text-xl font-semibold">
                <%= link_to metric.name, metric_path(metric) %>
              </h2>
              <p class="text-gray mt-1">
                Unit: <span class="font-medium"><%= metric.unit %></span>
                <% if metric.measurements.any? %>
                  <span class="ml-3">Latest: <span class="font-medium"><%= metric.measurements.order(recorded_at: :desc).first.value %> <%= metric.unit %></span></span>
                <% end %>
              </p>
            </div>
            <div class="flex gap-2">
              <%= link_to metric_path(metric), class: "icon-link", title: "View Chart" do %>
                <%= icon(:bar_chart, size: :sm) %>
              <% end %>
              <%= link_to edit_metric_path(metric), class: "icon-link", title: "Edit" do %>
                <%= icon(:edit, size: :sm) %>
              <% end %>
              <%= button_to metric, method: :delete, data: { turbo_confirm: "Are you sure? This will delete all measurements." }, class: "icon-link icon-link-danger", title: "Delete" do %>
                <%= icon(:trash, size: :sm) %>
              <% end %>
            </div>
          </div>

          <div class="mt-4">
            <p class="text-sm text-muted mb-2">Log measurement:</p>
            <%= form_with url: metric_measurements_path(metric), scope: :measurement, method: :post, class: "measurement-form" do |f| %>
              <%= f.number_field :value, step: :any, class: "form-input form-input-sm", placeholder: "Value", required: true %>
              <label class="measurement-form-date">
                <span class="text-sm text-muted">Date:</span>
                <%= f.datetime_local_field :recorded_at, value: Time.current.strftime("%Y-%m-%dT%H:%M"), class: "form-input form-input-sm" %>
              </label>
              <%= f.submit "Log", class: "btn btn-secondary btn-sm" %>
            <% end %>
          </div>

          <div class="mt-4">
            <p class="text-sm text-muted mb-2">Targets:</p>
            <% if metric.targets.any? %>
              <div class="stack-sm mb-3">
                <% metric.targets.reorder(applicable_from: :asc).each do |target| %>
                  <div class="flex-between text-sm">
                    <span><%= target.value %> <%= metric.unit %> from <%= target.applicable_from.to_date.strftime("%b %d, %Y") %></span>
                    <%= button_to "Delete", metric_target_path(metric, target), method: :delete, data: { turbo_confirm: "Delete this target?" }, class: "btn-link-danger text-xs" %>
                  </div>
                <% end %>
              </div>
            <% end %>
            <%= form_with url: metric_targets_path(metric), scope: :target, method: :post, class: "target-form" do |f| %>
              <%= f.number_field :value, step: :any, class: "form-input form-input-sm target-form-value", placeholder: "Target value" %>
              <label class="target-form-date">
                <span class="text-sm text-muted">From:</span>
                <%= f.date_field :applicable_from, value: Date.current, class: "form-input form-input-sm" %>
              </label>
              <%= f.submit "Add", class: "btn btn-secondary btn-sm" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted">No metrics defined yet. Create one to start tracking measurements like body weight or body measurements.</p>
  <% end %>
</div>
