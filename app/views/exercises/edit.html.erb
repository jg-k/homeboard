<% content_for :title, "Edit Exercise" %>

<div class="page-sm">
  <div class="mb-6">
    <%= link_to "&larr; Back".html_safe, @return_to || activity_path %>
  </div>

  <h1 class="page-title mb-6">Edit Exercise</h1>

  <div class="card">
    <%= form_with model: @exercise do |f| %>
      <% if @exercise.errors.any? %>
        <div class="form-errors">
          <h2><%= pluralize(@exercise.errors.count, "error") %> prohibited this activity from being saved:</h2>
          <ul>
            <% @exercise.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% if @return_to.present? %>
        <%= hidden_field_tag :return_to, @return_to %>
      <% end %>

      <div class="form-group">
        <%= f.label :exercise_type_id, "Exercise Type", class: "form-label" %>
        <p class="text-muted"><%= @exercise.exercise_type.name %></p>
        <%= f.hidden_field :exercise_type_id %>
      </div>

      <div class="form-group">
        <%= f.label :value, class: "form-label" do %>
          Value <span class="text-muted font-normal">(<%= @exercise.unit %>)</span>
        <% end %>
        <%= f.number_field :value, step: "any", class: "form-input", placeholder: "e.g., 100" %>
      </div>

      <% if @exercise.exercise_type.added_weight_possible? %>
        <div class="form-group">
          <%= f.label :added_weight, "Added Weight (kg)", class: "form-label" %>
          <%= f.number_field :added_weight, step: "any", class: "form-input", placeholder: "Optional" %>
        </div>
      <% end %>

      <div class="form-row">
        <div class="form-group">
          <%= f.label :reps, "Reps per set", class: "form-label" %>
          <%= f.number_field :reps, class: "form-input", placeholder: @exercise.exercise_type.reps ? "Default: #{@exercise.exercise_type.reps}" : "Optional" %>
        </div>
        <div class="form-group" data-controller="rpe-slider">
          <%= f.label :rpe, class: "form-label" do %>
            RPE <span class="text-muted font-normal" data-rpe-slider-target="display"><%= @exercise.rpe.present? ? @exercise.rpe : "–" %></span>
            <button type="button" class="btn-icon-inline <%= 'hidden' unless @exercise.rpe.present? %>" data-rpe-slider-target="clear" data-action="click->rpe-slider#clear" title="Clear RPE"><%= icon(:trash, size: :sm) %></button>
          <% end %>
          <%= f.hidden_field :rpe, data: { rpe_slider_target: "hidden" } %>
          <%= tag.input type: "range", min: 1, max: 10, step: 0.5, class: "form-range",
              value: @exercise.rpe || 5,
              data: { rpe_slider_target: "slider", action: "input->rpe-slider#update" } %>
        </div>
      </div>

      <div class="form-group">
        <%= f.label :performed_at, "Date & Time", class: "form-label" %>
        <%= f.datetime_local_field :performed_at, value: @exercise.activity_log.performed_at.strftime("%Y-%m-%dT%H:%M"), step: 60, class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :notes, class: "form-label" %>
        <%= f.text_area :notes, rows: 3, class: "form-textarea", placeholder: "Optional notes..." %>
      </div>

      <div class="form-actions">
        <%= f.submit "Update Exercise", class: "btn btn-primary" %>
        <%= link_to "Cancel", @return_to || activity_path, class: "btn-link-muted" %>
      </div>
    <% end %>
  </div>
</div>
