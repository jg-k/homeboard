<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title><%= content_for(:title) || "Homeboard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:meta_description) || "Track your climbing problems and fitness routines on your home climbing wall." %>">
    <meta property="og:title" content="<%= content_for(:title) || "Homeboard" %>">
    <meta property="og:description" content="<%= content_for(:meta_description) || "Track your climbing problems and fitness routines on your home climbing wall." %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://homeboard.zone">
    <meta property="og:image" content="https://homeboard.zone/icon.png">
    <link rel="canonical" href="https://homeboard.zone">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Homeboard">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%# Enable PWA manifest for installable apps %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <link rel="icon" href="/icon.png?v=2" type="image/png">
    <link rel="icon" href="/icon.svg?v=2" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png?v=2">
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <% if user_signed_in? %>
          <%= link_to root_path, class: "nav-brand" do %>
            <%= image_tag "crimp_white.svg", alt: "Homeboard", class: "nav-logo" %>
          <% end %>
          <!-- Mobile menu toggle (CSS-only) -->
          <input type="checkbox" id="mobile-menu-toggle" class="mobile-menu-checkbox">
          <label for="mobile-menu-toggle" class="nav-hamburger" aria-label="Menu">
            <svg class="hamburger-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg class="close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </label>
          <!-- Slide-out menu -->
          <div class="mobile-menu">
            <label for="mobile-menu-toggle" class="mobile-overlay"></label>
            <div class="mobile-menu-panel">
              <div class="mobile-menu-links">
                <!-- Desktop only - these are in bottom nav on mobile -->
                <%= link_to activity_path, class: "desktop-only" do %>
                  <%= icon(:calendar, css_class: "menu-icon") %>
                  Logbook
                <% end %>
                <%= link_to problems_landing_path, class: "desktop-only" do %>
                  <%= icon(:problem, css_class: "menu-icon") %>
                  Problems
                <% end %>
                <%= link_to new_exercise_path, class: "desktop-only" do %>
                  <%= icon(:barbell, css_class: "menu-icon") %>
                  Log Activity
                <% end %>
                <%= link_to stats_path do %>
                  <%= icon(:bar_chart, css_class: "menu-icon") %>
                  Stats
                <% end %>
                <%= link_to boards_path do %>
                  <%= icon(:board_grid, css_class: "menu-icon") %>
                  Boards
                <% end %>
                <%= link_to tracking_path do %>
                  <%= icon(:tag, css_class: "menu-icon") %>
                  Exercises & Metrics
                <% end %>
                <%= link_to buddies_path do %>
                  <%= icon(:users, css_class: "menu-icon") %>
                  Buddies
                <% end %>
                <%= link_to settings_path do %>
                  <%= icon(:gear, css_class: "menu-icon") %>
                  Settings
                <% end %>
                <%= link_to getting_started_path do %>
                  <%= icon(:help_circle, css_class: "menu-icon") %>
                  Get Started
                <% end %>
                <% if current_user.admin? %>
                  <%= link_to admin_users_path, class: "mobile-menu-admin" do %>
                    <%= icon(:shield, css_class: "menu-icon") %>
                    Admin
                  <% end %>
                <% end %>
              </div>
              <div class="mobile-menu-footer">
                <span class="mobile-menu-email"><%= current_user.email %></span>
                <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "btn btn-danger" %>
              </div>
            </div>
          </div>
        <% else %>
          <%= link_to root_path, class: "nav-brand" do %>
            <%= image_tag "crimp_white.svg", alt: "Homeboard", class: "nav-logo" %>
          <% end %>
        <% end %>
      </div>
    </nav>
    <% if notice.present? %>
      <div class="alert alert-success" data-controller="flash"><%= notice %></div>
    <% end %>
    <% if alert.present? %>
      <div class="alert alert-error" data-controller="flash"><%= alert %></div>
    <% end %>
    <main>
      <%= yield %>
    </main>
    <% if user_signed_in? %>
      <nav class="bottom-nav">
        <%= link_to activity_path, class: "bottom-nav-item", title: "Logbook" do %>
          <%= icon(:calendar, css_class: "bottom-nav-icon") %>
        <% end %>
        <%= link_to problems_landing_path, class: "bottom-nav-item", title: "Problems" do %>
          <%= icon(:problem, css_class: "bottom-nav-icon") %>
        <% end %>
        <%= link_to new_exercise_path, class: "bottom-nav-item", title: "Log Exercise" do %>
          <%= icon(:barbell, css_class: "bottom-nav-icon") %>
        <% end %>
        <label for="mobile-menu-toggle" class="bottom-nav-item" title="Menu">
          <%= icon(:menu, css_class: "bottom-nav-icon") %>
        </label>
      </nav>
    <% end %>
  </body>
</html>
