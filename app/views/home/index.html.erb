<% content_for :title, "Homeboard - Climbing Tracker" %>
<% content_for :meta_description, "Track problems on your home climbing wall. Mark holds, log sends, sync Kilter Board climbs, and monitor your training progress." %>
<div class="landing-page">
  <div class="landing-hero">
    <h1 class="text-4xl font-bold mb-4">Homeboard</h1>
    <p class="text-xl text-muted mb-6">
      Track your home board problems, climbing sessions, and training in one place.
    </p>
    <div class="landing-buttons">
      <%= link_to "Login", new_user_session_path, class: "btn btn-primary" %>
      <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-success" %>
    </div>
    <p class="font-semibold mt-6">— Free to use —</p>
  </div>
  <div class="landing-section">
    <div class="landing-screenshots">
      <div class="landing-screenshot">
        <div class="phone-frame">
          <div class="phone-screen">
            <%= image_tag "screenshot-problem.png", alt: "Problem Page" %>
          </div>
        </div>
        <p class="text-sm text-muted mt-4">Mark holds and build your homeboard problem library</p>
      </div>
      <div class="landing-screenshot">
        <div class="phone-frame">
          <div class="phone-screen">
            <%= image_tag "screenshot-activity.png", alt: "Activity Feed" %>
          </div>
        </div>
        <p class="text-sm text-muted mt-4">Compiled climbing and training activity feed</p>
      </div>
      <div class="landing-screenshot">
        <div class="phone-frame">
          <div class="phone-screen">
            <%= image_tag "screenshot-stats.png", alt: "Stats Page" %>
          </div>
        </div>
        <p class="text-sm text-muted mt-4">So many charts to ponder over</p>
      </div>
    </div>
  </div>
  <div class="landing-section">
    <h2 class="text-2xl font-semibold mb-4">What it does</h2>
    <div class="landing-features">
      <div class="landing-feature">
        <h3 class="font-semibold mb-2">Board Problems</h3>
        <p class="text-sm text-muted">
          Upload a photo of your board, mark holds, and create problems.
          Log attempts, sends, and flashes.
        </p>
      </div>
      <div class="landing-feature">
        <h3 class="font-semibold mb-2">Activity Log</h3>
        <p class="text-sm text-muted">
          All your climbing and training in one place.
          Board sessions, gym visits, outdoor climbs, exercises.
        </p>
      </div>
      <div class="landing-feature">
        <h3 class="font-semibold mb-2">Fitness Tracking</h3>
        <p class="text-sm text-muted">
          Track exercises by category (finger, core, upper body, etc.)
          and set targets for progression.
        </p>
      </div>
      <div class="landing-feature">
        <h3 class="font-semibold mb-2">Kilter Board Sync</h3>
        <p class="text-sm text-muted">
          Connect Boardsesh to sync your ticks from Kilter and Tension.
        </p>
      </div>
      <div class="landing-feature">
        <h3 class="font-semibold mb-2">Logbook Import</h3>
        <p class="text-sm text-muted">
          Import your outdoor ascents from theCrag or UKC.
        </p>
      </div>
    </div>
  </div>
  <div class="landing-section landing-footer">
    <p class="text-muted">
      <%= link_to "https://github.com/jg-k/homeboard", target: "_blank", rel: "noopener", class: "inline-icon-link" do %>
        <%= icon(:github, css_class: "icon-sm") %>
        <span>Source — issues, ideas, contributions</span>
      <% end %>
    </p>
    <p class="text-muted mt-2">
      Any questions? <%= mail_to "jegk@homeboard.zone" %>
    </p>
    <p class="text-muted mt-2">Made in Scotland
      <svg viewBox="0 0 24 24" width="18" height="18" class="scotland-heart">
        <defs>
          <clipPath id="heart-clip">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </clipPath>
        </defs>
        <g clip-path="url(#heart-clip)">
          <rect x="0" y="0" width="24" height="24" fill="#005EB8"/>
          <line x1="0" y1="0" x2="24" y2="24" stroke="white" stroke-width="4"/>
          <line x1="24" y1="0" x2="0" y2="24" stroke="white" stroke-width="4"/>
        </g>
      </svg>
    </p>
  </div>
</div>
