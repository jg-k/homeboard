<% content_for :title, "Edit Measurement" %>

<div class="page-sm">
  <div class="mb-6">
    <%= link_to "&larr; Back to #{@metric.name}".html_safe, metric_path(@metric) %>
  </div>

  <h1 class="page-title mb-6">Edit Measurement</h1>

  <div class="card">
    <%= form_with model: [@metric, @measurement] do |f| %>
      <% if @measurement.errors.any? %>
        <div class="form-errors">
          <h2><%= pluralize(@measurement.errors.count, "error") %> prohibited this measurement from being saved:</h2>
          <ul>
            <% @measurement.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-group">
        <%= f.label :value, class: "form-label" %>
        <%= f.number_field :value, step: :any, class: "form-input", required: true %>
        <p class="form-hint"><%= @metric.unit %></p>
      </div>

      <div class="form-group">
        <%= f.label :recorded_at, "Date & Time", class: "form-label" %>
        <%= f.datetime_local_field :recorded_at, value: @measurement.recorded_at.strftime("%Y-%m-%dT%H:%M"), class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :notes, class: "form-label" %>
        <%= f.text_area :notes, class: "form-input", rows: 3 %>
      </div>

      <div class="form-actions">
        <%= f.submit "Update", class: "btn btn-primary" %>
        <%= link_to "Cancel", metric_path(@metric), class: "btn btn-outline" %>
      </div>
    <% end %>
  </div>
</div>
