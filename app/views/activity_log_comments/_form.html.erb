<%= form_with model: comment, url: form_url do |f| %>
  <% if comment.errors.any? %>
    <div class="form-errors">
      <h2><%= pluralize(comment.errors.count, "error") %> prohibited this comment from being saved:</h2>
      <ul>
        <% comment.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :category, class: "form-label" %>
    <%= f.select :category,
        options_for_select(ActivityLogComment::CATEGORIES.map { |c| [c.titleize, c] }, comment.category || "obs"),
        {},
        class: "form-select" %>
  </div>

  <div class="form-group">
    <%= f.label :body, "Comment", class: "form-label" %>
    <%= f.text_area :body, rows: 4, class: "form-textarea",
        placeholder: "What did you notice? Safety lapses, observations, etc." %>
  </div>

  <div class="form-actions">
    <%= f.submit comment.persisted? ? "Update Comment" : "Add Comment", class: "btn btn-primary" %>
    <%= link_to "Cancel", activity_path, class: "btn btn-outline" %>
  </div>
<% end %>
