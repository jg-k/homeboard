<% content_for :title, "#{@user.email}'s Activity" %>

<div class="page">
  <div class="page-header-flex">
    <div>
      <h1 class="page-title"><%= @user.email %></h1>
      <p class="page-subtitle">Activity Log</p>
    </div>
    <div>
      <%= link_to "Back to Buddies", buddies_path, class: "btn btn-outline" %>
    </div>
  </div>

  <%= render "activity/activity_grid",
             activity_data: @activity_data,
             grid_day_url: ->(date) { day_buddy_path(@user, date: date.iso8601) },
             grid_link_data: { turbo_frame: "_top" } %>

  <% if @activity_logs.any? %>
    <div class="activity-list">
      <% @activity_logs_by_date.each do |date, logs| %>
        <div class="date-divider">
          <span class="date-divider-text"><%= date.strftime("%A, %B %d, %Y") %></span>
        </div>
        <div class="stack">
          <% logs.each do |activity_log| %>
            <% next if activity_log.hike? || activity_log.system_board_climb? %>
            <% loggable = @loggables_by_log_id[activity_log.id] %>
            <%= render ActivityCard.for(activity_log: activity_log, loggable: loggable, readonly: true, buddy: @user) if loggable %>
          <% end %>
        </div>
      <% end %>
    </div>

    <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
  <% else %>
    <div class="empty-state">
      <h3>No activity yet</h3>
      <p><%= @user.email %> hasn't logged any activity yet.</p>
    </div>
  <% end %>
</div>
