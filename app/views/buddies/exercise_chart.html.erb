<%= render PageLayout.new(title: @exercise_type.name, subtitle: "#{@user.email} &bull; #{@exercise_type.category.titleize} &bull; #{@exercise_type.unit}".html_safe) do %>
  <div class="mb-6">
    <%= link_to "&larr; Back to #{@user.email}'s Activity".html_safe, activity_buddy_path(@user) %>
  </div>

  <div class="card">
    <% has_data = @chart_data.is_a?(Array) && @chart_data.first.is_a?(Hash) ? @chart_data.any? { |s| s[:data].any? } : @chart_data.any? %>
    <% if has_data %>
      <%= line_chart @chart_data,
                     ytitle: @exercise_type.unit,
                     curve: false,
                     colors: ["#14b8a6", "#f59e0b"],
                     library: {
                       spanGaps: true,
                       datasets: [
                         {},
                         { borderDash: [5, 5] }
                       ],
                       scales: {
                         x: {
                           ticks: { color: "#9ca3af" },
                           grid: { color: "rgba(156, 163, 175, 0.2)" }
                         },
                         y: {
                           ticks: { color: "#9ca3af" },
                           grid: { color: "rgba(156, 163, 175, 0.2)" }
                         }
                       }
                     } %>
    <% else %>
      <p class="text-muted text-center py-8">No data yet.</p>
    <% end %>
  </div>
<% end %>
