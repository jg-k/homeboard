<% ascent_badge_color = case crag_ascent.ascent_type
  when "onsight", "flash" then :purple
  when "redpoint", "send" then :green
  when "attempt", "hang_dog" then :yellow
  else :gray
  end %>

<div class="card card-bordered card-crag-ascent activity-card">
  <div class="flex-between">
    <div>
      <div class="activity-header">
        <%= render Badge.new(:gray) { "Outdoor" } %>
        <% if crag_ascent.ascent_type.present? %>
          <%= render Badge.new(ascent_badge_color) { crag_ascent.ascent_type.titleize } %>
        <% end %>
        <% if crag_ascent.gear_style.present? %>
          <%= render Badge.new(:blue) { crag_ascent.gear_style.titleize } %>
        <% end %>
        <span class="activity-title"><%= crag_ascent.route_name %></span>
        <% if crag_ascent.grade.present? %>
          <span class="text-sm text-gray font-medium"><%= crag_ascent.grade %></span>
        <% end %>
      </div>

      <div class="activity-meta">
        <% if crag_ascent.crag_name.present? %>
          <span class="font-medium"><%= crag_ascent.crag_name %></span>
          <span> &bull; </span>
        <% end %>
        <span><%= smart_date(activity_log.performed_at) %></span>
      </div>

      <% if crag_ascent.comment.present? %>
        <div class="activity-notes">
          <%= simple_format(crag_ascent.comment) %>
        </div>
      <% end %>
    </div>

    <% unless local_assigns[:readonly] %>
      <%= render ActivityActions.new(
        delete_path: crag_ascent_path(crag_ascent),
        delete_confirm: "Are you sure you want to delete this outdoor ascent?"
      ) %>
    <% end %>
  </div>
</div>
