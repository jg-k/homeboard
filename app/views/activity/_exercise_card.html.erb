<div class="card card-bordered card-exercise activity-card">
  <div class="flex-between">
    <div>
      <div class="activity-header">
        <%= render Badge.new(:teal) {"Exercise"}%>
        <span class="activity-title"><%= exercise.name %></span>
        <span class="text-lg font-medium text-teal">
          <%= exercise.value %> <%= exercise.unit %><%
          %><%= " × #{exercise.effective_reps} reps" if exercise.effective_reps.present? %><%
          %><%= ", + #{exercise.added_weight.to_i}kg" if exercise.added_weight.present? %><%
          %><%= " @ RPE #{exercise.rpe}" if exercise.rpe.present? %><%
          %><%= ", #{exercise.rest_seconds}s rest" if exercise.rest_seconds.present? %>
        </span>
        <% chart_path = local_assigns[:buddy] ? exercise_chart_buddy_path(buddy, exercise_type_id: exercise.exercise_type_id) : exercise_type_path(exercise.exercise_type) %>
        <%= link_to chart_path, class: "btn-icon", title: "View exercise history", data: { turbo_frame: "_top" } do %>
          <%= icon(:bar_chart) %>
        <% end %>
      </div>
      <div class="activity-meta">
        <span><%= smart_date(activity_log.performed_at) %></span>
      </div>
      <% if exercise.notes.present? %>
        <div class="activity-notes">
          <%= simple_format(exercise.notes) %>
        </div>
      <% end %>
    </div>
    <% unless local_assigns[:readonly] %>
      <%= render ActivityActions.new(
        edit_path: edit_exercise_path(exercise),
        delete_path: exercise_path(exercise),
        delete_confirm: "Are you sure you want to delete this activity?",
        primary_action: {
          path: new_exercise_path(exercise_type_id: exercise.exercise_type_id, value: exercise.value, added_weight: exercise.added_weight, reps: exercise.effective_reps, category: exercise.exercise_type.category),
          title: "Duplicate to today",
          icon: :copy
        }
      ) %>
    <% end %>
  </div>
</div>
