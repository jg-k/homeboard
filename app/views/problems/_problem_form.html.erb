<%= form_with model: [@current_board, problem], url: problem.persisted? ? board_problem_path(@current_board, problem) : board_problems_path(@current_board, board_layout_id: problem.board_layout.id), data: { turbo_frame: "_top" } do |form| %>
  <div class="mb-4"
               data-controller="hold-marker"
               data-hold-marker-editable-value="true"
               data-hold-marker-start-holds-value="<%= problem.start_holds.to_json %>"
               data-hold-marker-finish-holds-value="<%= problem.finish_holds.to_json %>"
               data-hold-marker-hand-holds-value="<%= problem.hand_holds.to_json %>"
               data-hold-marker-foot-holds-value="<%= problem.foot_holds.to_json %>">
    <% if problem.errors.any? %>
      <div class="form-errors mb-4">
        <ul>
          <% problem.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <% if problem.board_layout.image_layout.attached? %>
      <div class="mb-4">
        <div class="hold-mode-controls">
          <button type="button" data-hold-marker-target="modeButton" data-mode="start" data-action="click->hold-marker#setMode" class="hold-mode-btn hold-mode-btn-active">
            Start
          </button>
          <button type="button" data-hold-marker-target="modeButton" data-mode="hand" data-action="click->hold-marker#setMode" class="hold-mode-btn hold-mode-btn-inactive">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2v0"/><path d="M14 10V4a2 2 0 0 0-2-2a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/></svg>
          </button>
          <button type="button" data-hold-marker-target="modeButton" data-mode="foot" data-action="click->hold-marker#setMode" class="hold-mode-btn hold-mode-btn-inactive">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="22" viewBox="0 0 22 28" fill="currentColor"><ellipse cx="7" cy="4" rx="2.2" ry="1.8"/><ellipse cx="11" cy="2.5" rx="2" ry="1.6"/><ellipse cx="15" cy="4" rx="1.8" ry="1.5"/><ellipse cx="18" cy="6.5" rx="1.5" ry="1.3"/><path d="M6 10c0-1 1.5-2 4-2h2c2.5 0 4 2 4 4.5c0 4.5-1.5 9-4 11.5c-1.5 1.2-4 1.2-5.5-1c-1.5-2.2-1.5-5.5-1.5-9c0-1.5 0-2.5 1-4z"/></svg>
          </button>
          <button type="button" data-hold-marker-target="modeButton" data-mode="finish" data-action="click->hold-marker#setMode" class="hold-mode-btn hold-mode-btn-inactive">
            Finish
          </button>
          <button type="button" data-action="click->hold-marker#clearAll" class="hold-mode-btn hold-mode-btn-danger">
            Clear
          </button>
        </div>
        <p class="text-sm text-muted mt-2">Click hold type, then tap image to mark positions</p>
      </div>
      <div
                data-hold-marker-target="container"
                data-action="click->hold-marker#imageClicked resize@window->hold-marker#windowResized"
                class="image-container mb-4">
        <%= image_tag problem.board_layout.display_image,
                    data: { hold_marker_target: "image" } %>
      </div>
    <% end %>
    <%= form.hidden_field :start_holds, data: { "hold-marker-target": "startHoldsInput" } %>
    <%= form.hidden_field :finish_holds, data: { "hold-marker-target": "finishHoldsInput" } %>
    <%= form.hidden_field :hand_holds, data: { "hold-marker-target": "handHoldsInput" } %>
    <%= form.hidden_field :foot_holds, data: { "hold-marker-target": "footHoldsInput" } %>
  </div>
  <div class="edit-form-fields">
    <div class="form-group mb-4">
      <%= form.label :name, class: "form-label" %>
      <%= form.text_field :name, class: "form-input text-xl font-semibold", placeholder: "Problem name" %>
    </div>
    <div class="form-group mb-4">
      <%= form.label :grade, class: "form-label" %>
      <% grading_system = @current_board.grading_system %>
      <% if grading_system %>
        <%= form.select :grade,
            options_for_select(grading_system.grades, problem.grade),
            { include_blank: "Select grade" },
            { class: "form-select" } %>
      <% else %>
        <%= form.text_field :grade, class: "form-input", placeholder: "No grading system set on board" %>
      <% end %>
    </div>
    <div class="form-group mb-4">
      <label class="radio-label">
        <%= form.check_box :circuit, class: "form-checkbox" %>
        <span>Circuit</span>
      </label>
    </div>
    <div class="flex gap-2">
      <%= form.submit problem.persisted? ? "Update" : "Create", class: "btn btn-primary" %>
      <%= link_to "Cancel",
                  problem.persisted? ? board_problem_path(@current_board, problem) : board_problems_path(@current_board),
                  class: "btn btn-secondary",
                  data: { turbo: false } %>
    </div>
  </div>
<% end %>
