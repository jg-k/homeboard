<% content_for :title, "Log In" %>

<div class="auth-page">
  <div class="auth-container">
    <div class="text-center mb-8">
      <h2 class="text-3xl font-bold">Log in to your account</h2>
    </div>

    <div class="oauth-buttons">
      <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, data: { turbo: false }, class: "btn btn-outline btn-full" do %>
        <svg class="oauth-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <span>Sign in with Google</span>
      <% end %>

      <%= button_to user_entra_id_omniauth_authorize_path, method: :post, data: { turbo: false }, class: "btn btn-outline btn-full" do %>
        <svg class="oauth-icon-microsoft" viewBox="0 0 21 21" xmlns="http://www.w3.org/2000/svg">
          <path fill="#f35325" d="M0 0h10v10H0z"/>
          <path fill="#81bc06" d="M11 0h10v10H11z"/>
          <path fill="#05a6f0" d="M0 11h10v10H0z"/>
          <path fill="#ffba08" d="M11 11h10v10H11z"/>
        </svg>
        <span>Sign in with Microsoft</span>
      <% end %>
    </div>

    <% if Rails.env.development? %>
      <div class="dev-only-notice">Development only — email login is not exposed in production.</div>
      <%= render "devise/sessions/email_form" %>
    <% end %>

    <div class="mt-6 text-center">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
