<% badge_color = board_climb.flash? ? :purple : (board_climb.sent? ? :green : (board_climb.circuit? ? :blue : :yellow)) %>
<div class="card card-bordered card-board-climb activity-card">
  <div class="flex-between">
    <div>
      <div class="activity-header">
        <%= render Badge.new(:gray) {"Board climb"}%>
        <%= render Badge.new(badge_color, size: :base) {board_climb.climb_type.titleize}%>
        <% if board_climb.attempts > 1 %>
          <span class="text-sm text-gray"><%= board_climb.attempts %> attempts</span>
        <% end %>
        <% if board_climb.number_of_moves.present? %>
          <span class="text-sm text-gray"><%= board_climb.number_of_moves %> moves</span>
        <% end %>
        <span class="activity-title"><%= board_climb.problem.name %><% if board_climb.problem.discarded? %> <span class="text-muted">(deleted)</span><% end %></span>
        <span class="text-sm text-gray font-medium"><%= board_climb.problem.grade %></span>
        <% if board_climb.circuit? %>
          <%= link_to board_problem_circuit_chart_path(board_climb.problem.board_layout.board, board_climb.problem), class: "btn-icon", title: "View circuit progress", data: { turbo_frame: "_top" } do %>
            <%= icon(:bar_chart) %>
          <% end %>
        <% end %>
      </div>
      <div class="activity-meta">
        <span class="font-medium"><%= board_climb.problem.board_layout.board.name %></span>
        <span> &bull; </span>
        <span><%= smart_date(activity_log.performed_at) %></span>
      </div>
      <% if board_climb.notes.present? %>
        <div class="activity-notes">
          <%= simple_format(board_climb.notes) %>
        </div>
      <% end %>
    </div>
    <% unless local_assigns[:readonly] %>
      <%= render ActivityActions.new(
        edit_path: edit_board_problem_board_climb_path(board_climb.problem.board_layout.board, board_climb.problem, board_climb),
        delete_path: board_problem_board_climb_path(board_climb.problem.board_layout.board, board_climb.problem, board_climb),
        delete_confirm: "Are you sure you want to delete this board climb?"
      ) %>
    <% end %>
  </div>
</div>
